# Supabase
# Project: hitotsu (ap-northeast-1)
# Dashboard: https://supabase.com/dashboard/project/wzjtkfurgevybfaimjxz
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site (used for auth redirect URL)
# 開発: http://localhost:3001
# 本番: https://hitotsu.v-corp.inc
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Anthropic Claude API (Server-side only, NEVER expose to client)
# console.anthropic.com → API Keys から取得
# 「今日のひとつ」生成に使用 (Claude Haiku 4.5)
ANTHROPIC_API_KEY=

# Stripe (V-Corp 親 ⊃ ひとつ 子アカウント: acct_1TTAXKKIix4iiOmw)
# Server-side: 秘密キー (ひとつアカウントの sk_live_...)
STRIPE_SECRET_KEY=
# Server-side: webhook 署名検証用 (whsec_...)
STRIPE_WEBHOOK_SECRET=
# Client-side OK: Checkout セッション作成時に使う Price ID
NEXT_PUBLIC_STRIPE_PRICE_ID=price_1TTKMgKIix4iiOmwElMC2Jer

# Supabase service role key (webhook で RLS をバイパスして書込)
# Server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist (カンマ区切りの メアド)
# ここに含まれる メアドのユーザーは課金スキップで全機能利用可
# 例: ADMIN_EMAILS=arata@v-corp.inc,admin2@example.com
ADMIN_EMAILS=arata@v-corp.inc

# Resend (メール送信、招待メール用)
# https://resend.com/api-keys から発行
# 招待メール送信に使用 (sender: noreply@v-corp.inc)
RESEND_API_KEY=

# α版招待制スイッチ
# true の時、新規サインアップ時に招待コードが必須になる
# 6/1 〜 1,000フォロワー or 7/1 までは true で運用
INVITE_REQUIRED=false
